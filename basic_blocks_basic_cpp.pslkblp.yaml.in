pluginName: basic_blocks_basic_cpp
pluginType: coreBlockLibrary
blockType: BasicCpp
version: @PROJECT_VERSION@
dependsOn:
  - name: PySysLinkBase
    version: @PYSYSLINK_BASE_VERSION@
  - name: BlockTypeSupportsBasicCpp
    version: @BLOCK_TYPE_SUPPORTS_BASIC_CPP_VERSION@
dynamicLibrary: libBlockLibrariesBasicBlocksBasicCpp-@PROJECT_VERSION@.so
commonBlocks:
  - name: TypedBlock
    configurationValues:
      - name: DataTypeCategory
        defaultValue: FullySupportedSignalValue
        type: options(Inherited, FullySupportedSignalValue)
      - name: DataType
        defaultValue: double
        type: enum(FullySupportedSignalValueType)
    inputPortTypes:
      all: 
        port_category: DataTypeCategory
        signal_value_type: DataType
        supported_port_types_for_inheritance: 
          - FullySupportedSignalValueType.Any
    outputPortTypes:
      all:
        port_category: DataTypeCategory
        signal_value_type: DataType
        supported_port_types_for_inheritance: 
          - FullySupportedSignalValueType.Any
blockLibraries:
  - name: BasicBlocks
    blockTypes:
      - name: Accumulator
        commonBlock: TypedBlock
        configurationValues:
          - name: InitialValue
            defaultValue: 0
            type: float
          - name: SampleTime
            defaultValue: 1
            type: float
        inputPortNumber: 1
        outputPortNumber: 1
      - name: Adder
        commonBlock: TypedBlock
        configurationValues:
          - name: Gains
            defaultValue:
            - 1
            - 1
            type: float[]
        inputPortNumber: length(Gains)
        outputPortNumber: 1
        renderInformation:
          blockShape: circle

      - name: Constant
        commonBlock: TypedBlock
        configurationValues:
          - name: Value
            defaultValue: 1
            type: float
        inputPortNumber: 0
        outputPortNumber: 1
      - name: ContinuousToDiscrete
        commonBlock: TypedBlock
        configurationValues:
          - name: ContinuousSampleTimeGroup
            defaultValue: 1
            type: int
          - name: DiscreteSampleTime
            defaultValue: 1.0
            type: float
        inputPortNumber: 1
        outputPortNumber: 1
      - name: Display
        commonBlock: TypedBlock
        inputPortNumber: 1
        outputPortNumber: 0
      - name: Integrator
        configurationValues:
          - name: InitialValue
            defaultValue: 0
            type: float
          - name: ContinuousSampleTimeGroup
            defaultValue: 1
            type: int
        inputPortNumber: 1
        inputPortTypes:
          all: 
            port_category: FullySupportedSignalValue
            signal_value_type: double
        outputPortNumber: 1
        outputPortTypes:
          all: 
            port_category: FullySupportedSignalValue
            signal_value_type: double
      - name: Gain
        commonBlock: TypedBlock
        configurationValues:
          - name: Gain 
            defaultValue: 1
            type: float
        inputPortNumber: 1
        outputPortNumber: 1
        renderInformation:
          blockShape: triangle

